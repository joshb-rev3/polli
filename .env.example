# Local development only (Expo). Netlify Production uses Site settings → Environment variables.
# Expo bakes EXPO_PUBLIC_* into the JS bundle at build/start time.

# ── Client (also set these on Netlify for web deploys) ───────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_or_publishable_key
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Optional: force the fake demo transcript (never set this on Netlify Production)
# EXPO_PUBLIC_MOCK_TRANSCRIBE=1

# ── Server-only helpers for local `supabase functions serve --env-file .env` ─
# Production equivalents live in Supabase secrets (NOT Netlify):
#   npx supabase secrets set ASSEMBLYAI_API_KEY=... STRIPE_SECRET_KEY=...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
ASSEMBLYAI_API_KEY=your_assemblyai_key
APP_DEEP_LINK=polli://
PUBLIC_SHARE_HOST=polli.to
